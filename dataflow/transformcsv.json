{
	"name": "transformcsv",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dataflowsource",
						"type": "DatasetReference"
					},
					"name": "sourcecsv"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "loaddata",
						"type": "DatasetReference"
					},
					"name": "loaddata"
				}
			],
			"transformations": [
				{
					"name": "selectrow"
				},
				{
					"name": "filterrow"
				},
				{
					"name": "splitcard"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          transaction_id as short,",
				"          transactional_date as timestamp,",
				"          product_id as string,",
				"          customer_id as short,",
				"          payment as string,",
				"          credit_card as long,",
				"          loyalty_card as boolean,",
				"          cost as double,",
				"          quantity as short,",
				"          price as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourcecsv",
				"sourcecsv select(mapColumn(",
				"          transaction_id,",
				"          transactional_date,",
				"          product_id,",
				"          customer_id,",
				"          payment,",
				"          price",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectrow",
				"selectrow filter(customer_id!=5) ~> filterrow",
				"filterrow split(payment=='visa',",
				"     payment=='americanexpress',",
				"     disjoint: false) ~> splitcard@(visa, amex, otherthanvisa)",
				"splitcard@visa aggregate(groupBy(customer_id,",
				"          payment),",
				"     product_id = max(product_id)) ~> aggregate1",
				"splitcard@otherthanvisa filter(transaction_id==4) ~> filter1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> loaddata"
			]
		}
	}
}